{
  "name": "@philiprehberger/semver-ts",
  "version": "0.1.4",
  "description": "Lightweight semver parsing, comparison, and range matching",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "node --test"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "semver",
    "version",
    "semantic-versioning",
    "compare",
    "range",
    "parse"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-semver.git"
  },
  "homepage": "https://github.com/philiprehberger/ts-semver#readme",
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-semver/issues"
  },
  "author": "Philip Rehberger",
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
